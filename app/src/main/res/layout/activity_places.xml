<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#00000000"
        app:title="Nearby Services"
        app:titleTextColor="@color/text_primary" />

    <!-- Category Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingBottom="@dimen/spacing_medium"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPolice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_small"
                android:backgroundTint="@color/color_police"
                android:text="🚔 Police"
                android:textColor="@color/white"
                app:cornerRadius="20dp" />

            <Button
                android:id="@+id/btnHospital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_small"
                android:backgroundTint="@color/color_hospital"
                android:text="🏥 Hospital"
                android:textColor="@color/white"
                app:cornerRadius="20dp" />

            <Button
                android:id="@+id/btnFire"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_small"
                android:backgroundTint="@color/color_fire"
                android:text="🚒 Fire Station"
                android:textColor="@color/white"
                app:cornerRadius="20dp" />
                
            <Button
                android:id="@+id/btnPharmacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_small"
                android:backgroundTint="#8E44AD"
                android:text="💊 Pharmacy"
                android:textColor="@color/white"
                app:cornerRadius="20dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/listTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingVertical="@dimen/spacing_small"
        android:text="Emergency Numbers"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_medium"
        android:textStyle="bold" />

    <!-- Emergency Numbers List -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:indeterminateTint="@color/colorPrimary" />
        
    <ListView
        android:id="@+id/emergencyNumbersList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="@dimen/spacing_small"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingBottom="@dimen/spacing_medium"
        android:clipToPadding="false" />

</LinearLayout>